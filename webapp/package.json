{
  "name": "alas",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=v14.14",
    "npm": ">=7.7"
  },
  "scripts": {
    "build": "vite build --config packages/renderer/vite.config.mjs",
    "watch": "vite --host 127.0.0.1 --config packages/renderer/vite.config.mjs",
    "lint": "eslint . --ext js,ts,vue",
    "typecheck-renderer": "vue-tsc --noEmit -p packages/renderer/tsconfig.json",
    "typecheck": "pnpm run typecheck-renderer"
  },
  "browserslist": [
    "defaults"
  ],
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run typecheck"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --cache --fix"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@typescript-eslint/eslint-plugin": "4.32.0",
    "@vitejs/plugin-vue": "1.9.2",
    "eslint": "7.32.0",
    "eslint-plugin-vue": "7.18.0",
    "lint-staged": "11.1.2",
    "simple-git-hooks": "2.6.1",
    "typescript": "4.4.2",
    "vite": "2.6.2",
    "vue-tsc": "0.3.0"
  },
  "dependencies": {
    "vue": "3.2.19",
    "vue-router": "4.0.11"
  }
}
